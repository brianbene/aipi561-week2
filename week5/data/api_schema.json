{
  "endpoints": {
    "/api/employees/{id}": {
      "method": "GET",
      "description": "Get employee information",
      "requires_auth": true,
      "access_control": "view_employee_directory",
      "fields": [
        {
          "name": "id",
          "sensitive": false
        },
        {
          "name": "name",
          "sensitive": false
        },
        {
          "name": "email",
          "sensitive": false
        },
        {
          "name": "department_name",
          "sensitive": false
        },
        {
          "name": "job_level",
          "sensitive": false
        },
        {
          "name": "title",
          "sensitive": false
        },
        {
          "name": "salary",
          "sensitive": true,
          "visibility": [
            "executive",
            "hr",
            "finance"
          ]
        },
        {
          "name": "ssn",
          "sensitive": true,
          "visibility": [
            "hr"
          ],
          "redact": true
        },
        {
          "name": "address",
          "sensitive": true,
          "visibility": [
            "hr"
          ]
        },
        {
          "name": "phone",
          "sensitive": false
        },
        {
          "name": "hire_date",
          "sensitive": false
        },
        {
          "name": "manager_id",
          "sensitive": false
        }
      ]
    },
    "/api/expenses": {
      "method": "GET",
      "description": "Get expense records",
      "requires_auth": true,
      "access_control": "view_all_expenses",
      "filtering": [
        "employee_id",
        "status",
        "date_range",
        "category"
      ]
    },
    "/api/projects/{id}": {
      "method": "GET",
      "description": "Get project information",
      "requires_auth": true,
      "access_control": "view_project_details"
    },
    "/api/salary-band/{level}": {
      "method": "GET",
      "description": "Get salary band information",
      "requires_auth": true,
      "access_control": "view_other_salaries",
      "data_type": "aggregated"
    }
  },
  "data_sources": {
    "employees": {
      "source": "employees table",
      "record_count": "5000+",
      "sensitivity": "high",
      "pii_fields": [
        "ssn",
        "salary",
        "address",
        "phone"
      ]
    },
    "expenses": {
      "source": "expenses table",
      "record_count": "50000+",
      "sensitivity": "medium",
      "pii_fields": [
        "employee_name",
        "vendor"
      ]
    },
    "projects": {
      "source": "projects table",
      "record_count": "100+",
      "sensitivity": "low"
    }
  }
}